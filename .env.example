# =============================================================================
# MySQL Backup to S3 — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# Reference: https://github.com/databacker/mysql-backup/blob/main/docs/configuration.md
# =============================================================================

# ─── Database Connection (LAN) ───────────────────────────────────────────────
DB_HOST=192.168.1.50            # IP/hostname of MySQL/MariaDB server
DB_PORT=3306                    # MySQL port (default: 3306)
DB_USER=backup_user             # Dedicated backup user (see README for setup SQL)
DB_PASSWORD=your_secure_password
DB_NAMES=                       # Databases to backup (comma-separated for upstream image)
                                # Leave empty to backup ALL databases

# ─── S3-Compatible Storage (iDrive e2 / AWS S3 / MinIO / R2) ────────────────
S3_BUCKET_NAME=my-db-backups
S3_PREFIX=db-backups            # Folder prefix inside bucket
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT_URL=https://s3.us-east-1.idrivee2.com   # iDrive e2 endpoint
S3_REGION=us-east-1             # Region of your bucket

# ─── Schedule & Timezone ─────────────────────────────────────────────────────
BACKUP_CRON=0 2 * * *           # Cron expression (default: 2:00 AM daily)
TZ=Asia/Ho_Chi_Minh             # Timezone for cron schedule

# ─── Backup Options ──────────────────────────────────────────────────────────
# Retention: how long to keep backups before auto-pruning (in hours)
# Examples: 720h = 30 days, 2160h = 90 days, 168h = 7 days
BACKUP_RETENTION=720h

# ─── Debug ────────────────────────────────────────────────────────────────────
# DB_DEBUG=true                 # Uncomment for verbose logging

# ─── Encryption (optional, for manual backup script only) ────────────────────
# BACKUP_GPG_PASSPHRASE=your_gpg_passphrase

# ─── Notifications (optional, for healthcheck script) ────────────────────────
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
